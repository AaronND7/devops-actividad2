# Configuración del proyecto DevOps Actividad 2
# Este archivo contiene variables de configuración para el deploy

# Configuración AWS
REGION=us-east-1

# Configuración EC2
INSTANCE_ID=i-1234567890abcdef0

# Configuración S3
BUCKET_NAME=mi-bucket-devops
DIRECTORY=./data

# Configuración de logging
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=30

# NOTA: Este archivo no debe contener credenciales sensibles
# Las credenciales deben configurarse mediante AWS CLI o variables de entorno
